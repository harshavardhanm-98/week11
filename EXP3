#include <stdio.h>
struct Student {
    int rollNo;
    char name[30];
    float marks;
};
int main() {
    struct Student s[3];
    int i;
    for(i = 0; i < 3; i++) {
        printf("Enter Roll No, Name, and Marks for student %d: ", i+1);
        scanf("%d %s %f", &s[i].rollNo, s[i].name, &s[i].marks);
    }
    printf("\nStudent Records:\n");
    for(i = 0; i < 3; i++) {
        printf("Roll: %d, Name: %s, Marks: %.1f\n", s[i].rollNo, s[i].name, s[i].marks);
    }
    printf("\nREG NO:25331A05I5");
    return 0;
}
